                contactAddressVal: "دبي، الإمارات العربية المتحدة",
                contactPhoneLabel: "الهاتف",
                contactEmailLabel: "البريد الإلكتروني",
                contactName: "الاسم الكامل",
                contactPhone: "رقم الهاتف",
                contactEmail: "البريد الإلكتروني",
                contactSubject: "الموضوع",
                contactMessage: "رسالتك",
                contactSubmit: "إرسال الرسالة",
                footerDesc: "خدمات متميزة في صيانة المباني وإدارة المرافق في جميع أنحاء الإمارات العربية المتحدة.",
                footerLinks: "روابط سريعة",
                footerServices: "خدماتنا",
                privacyPolicy: "سياسة الخصوصية",
                termsOfService: "شروط الخدمة",
                footerRights: "© 2024 وود جوينت لصيانة المباني. جميع الحقوق محفوظة."
            }
        };

        let currentLang = 'en';

        function toggleLanguage() {
            currentLang = currentLang === 'en' ? 'ar' : 'en';
            
            // Toggle HTML direction & language
            document.documentElement.dir = currentLang === 'en' ? 'ltr' : 'rtl';
            document.documentElement.lang = currentLang;
            
            // Update all elements with data-i18n attribute
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[currentLang][key]) {
                    el.innerHTML = translations[currentLang][key];
                }
            });
        }
        // Go to Top Button visibility
        const goToTopBtn = document.getElementById('goToTopBtn');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                goToTopBtn.classList.remove('scale-0', 'opacity-0');
                goToTopBtn.classList.add('scale-100', 'opacity-100');
            } else {
                goToTopBtn.classList.remove('scale-100', 'opacity-100');
                goToTopBtn.classList.add('scale-0', 'opacity-0');
            }
        });
    </script>
</body>
</html>