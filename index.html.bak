  <script data-arena-views="true">(function(){var isTop=false;try{isTop=window.self===window.top;}catch(e){}if(!isTop)return;window.__ARENA_META={generationId:"gemini-3.1-pro-preview",tournamentId:"1d142196-1ab9-480c-a2ae-f221b0588a05"};var payload={tournamentId:"1d142196-1ab9-480c-a2ae-f221b0588a05",modelId:"gemini-3.1-pro-preview"};try{var r=document.referrer;if(r){var u=new URL(r);payload.referrerDomain=u.hostname;}}catch(e){}try{var vid=null;try{vid=localStorage.getItem('arena_vid');}catch(e){}if(!vid){vid=typeof crypto!=="undefined"&&crypto.randomUUID?crypto.randomUUID():(Date.now().toString(36)+Math.random().toString(36).slice(2)).slice(0,32);try{localStorage.setItem('arena_vid',vid);}catch(e){}}if(vid)payload.viewerId=vid;}catch(e){}try{fetch("https://www.designarena.ai/api/agon/page-views",{"method":"POST","headers":{"Content-Type":"application/json"},"body":JSON.stringify(payload),"keepalive":true});}catch(e){}})();</script>
</head>
<body class="bg-white text-gray-900 antialiased overflow-x-hidden">

    <!-- Navbar -->
    <nav id="navbar" class="fixed w-full z-50 transition-all duration-300 bg-white/90 backdrop-blur-md shadow-sm py-4">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <img src="./logo.png" alt="WoodJoint" class="h-10 w-10 object-contain" />
                <div class="flex flex-col">
                    <span class="text-xl font-bold text-brand-900 leading-tight">WoodJoint</span>
                    <span class="text-[10px] text-gray-500 uppercase tracking-wider">Building Maintenance</span>
                </div>
            </div>

            <div class="hidden md:flex items-center gap-8">
                <a href="#home" class="text-gray-700 hover:text-brand-600 font-medium" data-i18n="navHome">Home</a>
                <a href="#about" class="text-gray-700 hover:text-brand-600 font-medium" data-i18n="navAbout">About Us</a>
                <a href="#services" class="text-gray-700 hover:text-brand-600 font-medium" data-i18n="navServices">Services</a>
                <a href="#projects" class="text-gray-700 hover:text-brand-600 font-medium" data-i18n="navProjects">Projects</a>
                <a href="#contact" class="text-gray-700 hover:text-brand-600 font-medium" data-i18n="navContact">Contact</a>
                
                <button onclick="toggleLanguage()" class="flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 hover:bg-gray-50 text-gray-700 transition-colors font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span data-i18n="navLang">العربية</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <section id="home" class="relative h-screen w-full overflow-hidden bg-gray-900 flex items-center justify-center text-center">
        <div class="absolute inset-0">
            <div class="absolute inset-0 bg-black/50 z-10"></div>
            <img src="./images/hero1.jpg" alt="Hero background" class="w-full h-full object-cover opacity-80" />
        </div>

        <div class="relative z-20 px-4 max-w-5xl mx-auto fade-in">
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight drop-shadow-lg" data-i18n="heroTitle">
                Excellence in Building Maintenance
            </h1>
            <p class="text-lg md:text-2xl text-gray-200 mb-10 max-w-3xl mx-auto drop-shadow-md" data-i18n="heroSub">
                Delivering world-class facility management and maintenance services across the UAE.
            </p>
            <a href="#services" class="inline-block bg-brand-600 hover:bg-brand-700 text-white px-8 py-4 rounded-full font-semibold text-lg transition-transform hover:scale-105 shadow-lg" data-i18n="heroCta">
                Discover Our Services
            </a>
        </div>
    </section>

    <!-- About -->
    <section id="about" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="relative">
                    <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl">
                        <img src="./images/hero2.jpg" alt="WoodJoint Team" class="w-full h-full object-cover" />
                    </div>
                    <div class="absolute -bottom-8 -end-8 bg-brand-900 text-white p-8 rounded-2xl shadow-xl hidden md:block">
                        <div class="text-4xl font-bold mb-2">15+</div>
                        <div class="text-brand-100" data-i18n="aboutExpBadge">Years of Excellence<br/>in the UAE</div>
                    </div>
                </div>

                <div>
                    <div class="inline-block px-4 py-1.5 bg-brand-50 text-brand-700 font-semibold rounded-full mb-6" data-i18n="aboutLabel">
                        About WoodJoint
                    </div>
                    <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight" data-i18n="aboutTitle">
                        Your Trusted Partner in Building Maintenance
                    </h2>
                    <p class="text-lg text-gray-600 mb-6 leading-relaxed" data-i18n="aboutDesc1">
                        WoodJoint Building Maintenance is a premier facility management and maintenance company operating in the UAE. We specialize in providing comprehensive, high-quality technical services for residential, commercial, and industrial properties.
                    </p>
                    <p class="text-lg text-gray-600 mb-10 leading-relaxed" data-i18n="aboutDesc2">
                        With a commitment to excellence, international standards, and a customer-centric approach, our team of skilled engineers and technicians ensures that your property is maintained to the highest standards of safety, functionality, and aesthetics.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="services" class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <div class="inline-block px-4 py-1.5 bg-brand-100 text-brand-700 font-semibold rounded-full mb-4" data-i18n="servicesLabel">
                    Our Premium Services
                </div>
                <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6" data-i18n="servicesTitle">
                    Comprehensive maintenance solutions tailored to your needs.
                </h2>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Service 1 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
                    <div class="h-48 overflow-hidden relative">
                        <img src="./images/service-ac.jpg" alt="AC" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="srv1Title">Air-Conditioning & Ventilation</h3>
                        <p class="text-gray-600 leading-relaxed" data-i18n="srv1Desc">Installation and maintenance of HVAC and air filtration systems ensuring optimal indoor air quality.</p>
                    </div>
                </div>

                <!-- Service 2 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
                    <div class="h-48 overflow-hidden relative">
                        <img src="./images/hero3.jpg" alt="Pools" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="srv2Title">Swimming Pools Maintenance</h3>
                        <p class="text-gray-600 leading-relaxed" data-i18n="srv2Desc">Regular cleaning, chemical balancing, and equipment maintenance for pristine swimming pools.</p>
                    </div>
                </div>

                <!-- Service 3 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
                    <div class="h-48 overflow-hidden relative">
                        <img src="./images/service-building.jpg" alt="Building" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="srv3Title">Building Maintenance</h3>
                        <p class="text-gray-600 leading-relaxed" data-i18n="srv3Desc">Complete facility management covering structural repairs, painting, and preventive care.</p>
                    </div>
                </div>
                
                <!-- Service 4 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
                    <div class="h-48 overflow-hidden relative">
                        <img src="./images/service-tiles.jpg" alt="Tiling" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="srv4Title">Floor & Wall Tiling</h3>
                        <p class="text-gray-600 leading-relaxed" data-i18n="srv4Desc">Expert installation and repair of all types of tiles with precision and high-quality finishes.</p>
                    </div>
                </div>

                <!-- Service 5 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
                    <div class="h-48 overflow-hidden relative">
                        <img src="./images/service-electrical.jpg" alt="Electrical" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="srv5Title">Electrical Services</h3>
                        <p class="text-gray-600 leading-relaxed" data-i18n="srv5Desc">Safe and reliable electrical installations, repairs, and maintenance by certified electricians.</p>
                    </div>
                </div>

                <!-- Service 6 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-gray-100 group">
                    <div class="h-48 overflow-hidden relative">
                        <img src="./images/service-plumbing.jpg" alt="Plumbing" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3" data-i18n="srv6Title">Plumbing & Sanitary</h3>
                        <p class="text-gray-600 leading-relaxed" data-i18n="srv6Desc">Efficient plumbing contracting, leak repairs, and sanitary fixture installations.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
                <div class="max-w-2xl">
                    <div class="inline-block px-4 py-1.5 bg-brand-50 text-brand-700 font-semibold rounded-full mb-4" data-i18n="navProjects">
                        Projects
                    </div>
                    <h2 class="text-3xl md:text-5xl font-bold text-gray-900" data-i18n="projTitle">
                        Our Latest Completed Projects
                    </h2>
                </div>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="group relative overflow-hidden rounded-3xl cursor-pointer">
                    <div class="aspect-[4/5] overflow-hidden">
                        <img src="./images/hero1.jpg" alt="Project 1" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent opacity-80"></div>
                    <div class="absolute bottom-0 left-0 w-full p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                        <div class="text-brand-300 text-sm font-semibold mb-2" data-i18n="proj1Cat">Building Maintenance</div>
                        <h3 class="text-white text-2xl font-bold" data-i18n="proj1Title">Commercial Tower Maintenance</h3>
                    </div>
                </div>
                <div class="group relative overflow-hidden rounded-3xl cursor-pointer">
                    <div class="aspect-[4/5] overflow-hidden">
                        <img src="./images/hero3.jpg" alt="Project 2" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent opacity-80"></div>
                    <div class="absolute bottom-0 left-0 w-full p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                        <div class="text-brand-300 text-sm font-semibold mb-2" data-i18n="proj2Cat">Pool Maintenance</div>
                        <h3 class="text-white text-2xl font-bold" data-i18n="proj2Title">Luxury Villa Pool Care</h3>
                    </div>
                </div>
                <div class="group relative overflow-hidden rounded-3xl cursor-pointer">
                    <div class="aspect-[4/5] overflow-hidden">
                        <img src="./images/service-ac.jpg" alt="Project 3" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent opacity-80"></div>
                    <div class="absolute bottom-0 left-0 w-full p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                        <div class="text-brand-300 text-sm font-semibold mb-2" data-i18n="proj3Cat">Air-Conditioning</div>
                        <h3 class="text-white text-2xl font-bold" data-i18n="proj3Title">Industrial HVAC Upgrade</h3>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="py-24 bg-brand-50/30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16">
                <!-- Info Side -->
                <div>
                    <div class="inline-block px-4 py-1.5 bg-brand-100 text-brand-700 font-semibold rounded-full mb-6" data-i18n="contactLabel">Get In Touch</div>
                    <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-8 leading-tight" data-i18n="contactTitle">Ready to upgrade your property maintenance?</h2>
                    
                    <div class="space-y-8 mt-12">
                        <!-- Address -->
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-white text-brand-600 rounded-2xl shadow-sm flex items-center justify-center shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <div>
                                <h4 class="text-lg font-bold text-gray-900 mb-1" data-i18n="contactAddress">Address</h4>
                                <p class="text-gray-600" data-i18n="contactAddressVal">Dubai, United Arab Emirates</p>
                            </div>
                        </div>
                        <!-- Phone -->
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-white text-brand-600 rounded-2xl shadow-sm flex items-center justify-center shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <div>
                                <h4 class="text-lg font-bold text-gray-900 mb-1" data-i18n="contactPhoneLabel">Phone</h4>
                                <p class="text-gray-600" dir="ltr">+971 50 123 4567</p>
                            </div>
                        </div>
                        <!-- Email -->
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-white text-brand-600 rounded-2xl shadow-sm flex items-center justify-center shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            <div>
                                <h4 class="text-lg font-bold text-gray-900 mb-1" data-i18n="contactEmailLabel">Email</h4>
                                <p class="text-gray-600">info@woodjoint.ae</p>
                            </div>
                        </div>
                    </div>
                </div>

